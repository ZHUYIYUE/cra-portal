# Normalize text files across macOS and Windows.
* text=auto

# Source and docs should stay UTF-8 text in the repository.
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.sql text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf

# Windows batch files should keep CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Office/templates and images are binary.
*.doc binary
*.docx binary
*.xlsx binary
*.xls binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary